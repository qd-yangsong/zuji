// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  openid         String   @unique
  unionid        String?  @unique
  nickname       String?
  avatarUrl      String?
  signature      String?  // 个性签名（「我的」页面封面）
  role           String   @default("user") // user | admin
  status         String   @default("active") // active | banned
  bannedAt       DateTime?
  bannedReason   String?
  password       String?  // 仅 admin 账号有密码（bcrypt 哈希）
  stickerUnlocks String[] // 已解锁的贴纸 ID 列表（纪念+成就贴纸）
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  places  Place[]
  routes  Route[]

  @@map("users")
}

// 标签组 —— 用于场景标签的编组（如"陪伴场景""社交场景"）
model TagGroup {
  id        String   @id @default(cuid())
  userId    String?  // null = 系统预设，所有用户共享
  name      String   // 组名，如"陪伴场景"
  color     String?  // 组颜色（十六进制），如"#FF6B6B"
  icon      String?  // 组图标（emoji 或图标名）
  tagType   String   // 该组允许的标签类型，目前仅 "scene"
  isSystem  Boolean  @default(false) // 是否系统预设
  tags      Tag[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("tag_groups")
}

// 标签 —— 五层体系：attribute（属性）/ scene（场景）/ event（事件）/ vibe（氛围）/ category（客观分类）
model Tag {
  id          String    @id @default(cuid())
  userId      String?   // null = 系统预设，所有用户共享
  name        String    // 标签名称
  type        String    // attribute | scene | event | vibe | category
  groupId     String?   // 所属标签组（仅 scene 类型可归组）
  isSystem    Boolean   @default(false) // 是否系统预设
  usageCount  Int       @default(0) // 使用次数，用于热门排序
  group       TagGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  placeTags   PlaceTag[]
  checkinTags CheckInTag[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, type])
  @@map("tags")
}

// 地点 —— 用户收藏的地点，关联属性标签和场景标签
model Place {
  id              String    @id @default(cuid())
  userId          String    // 所属用户
  realName        String    // 地点真实名称（如"海底捞火锅（南门店）"）
  customName      String    // 用户自定义昵称（如"我家楼下深夜小馆"）
  latitude        Float     // 纬度
  longitude       Float     // 经度
  address         String?   // 详细地址
  coverImage      String?   // 封面图 URL
  checkinCount    Int       @default(0) // 打卡次数（计算字段，由 CheckIn 触发更新）
  collectedAt     DateTime  @default(now()) // 收藏时间
  // 「收藏即记录」字段
  firstImpression String?   // 首次感受文字
  firstImages     String[]  // 首次记录的照片
  // 情感评估
  rating          Int?      // 评分 1-5
  wantToRevisit   Boolean   @default(false) // 想再去
  // 贴纸
  stickerIds      String[]  // 已贴上的贴纸 ID 列表
  // 审核
  reviewStatus    String    @default("passed") // passed | pending | rejected
  reviewReason    String?   // 审核拒绝原因
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags            PlaceTag[]
  checkins        CheckIn[]
  collections     CollectionPlace[]
  routePlaces     RoutePlace[]

  @@index([userId])
  @@index([userId, collectedAt])
  @@map("places")
}

// 地点-标签中间表（多对多）
model PlaceTag {
  id        String   @id @default(cuid())
  placeId   String
  tagId     String
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([placeId, tagId])
  @@index([tagId])
  @@map("place_tags")
}

// 打卡记录 —— 用户在某个地点的一次到访记录
model CheckIn {
  id           String    @id @default(cuid())
  placeId      String    // 关联地点
  userId       String    // 所属用户
  content      String?   // 文字日记
  images       String[]  // 图片 URL 列表（PostgreSQL 数组）
  isFirst      Boolean   @default(false) // 是否首次收藏时的记录
  checkinAt    DateTime  @default(now()) // 打卡时间
  stickerIds   String[]  // 打卡记录的贴纸
  reviewStatus String    @default("passed") // passed | pending | rejected
  reviewReason String?   // 审核拒绝原因
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  place        Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  tags         CheckInTag[]

  @@index([placeId, checkinAt])
  @@index([userId])
  @@map("checkins")
}

// 打卡-事件标签中间表（多对多）
model CheckInTag {
  id         String   @id @default(cuid())
  checkinId  String
  tagId      String
  checkin    CheckIn  @relation(fields: [checkinId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([checkinId, tagId])
  @@index([tagId])
  @@map("checkin_tags")
}

// 地点合集 —— 用户自定义打包多个地点（如"成都美食10选"）
model Collection {
  id          String   @id @default(cuid())
  userId      String   // 所属用户
  name        String   // 合集名称
  description String?  // 合集描述
  coverImage  String?  // 合集封面图
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  places      CollectionPlace[]

  @@index([userId])
  @@map("collections")
}

// 合集-地点中间表（多对多）— 保留向后兼容，新功能走 Route
model CollectionPlace {
  id           String   @id @default(cuid())
  collectionId String
  placeId      String
  sort         Int      @default(0) // 排序序号
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  place        Place      @relation(fields: [placeId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([collectionId, placeId])
  @@index([placeId])
  @@map("collection_places")
}

// ========== 路线系统（v2 合集升级） ==========

// 路线 —— 有序的地点集合。支持「合集（无序分类）」和「旅程（有序攻略）」两种模式
model Route {
  id          String      @id @default(cuid())
  userId      String      // 所属用户
  name        String      // 路线名称
  description String?     // 路线描述
  coverImage  String?     // 封面图
  type        String      @default("collection") // collection | journey
  status      String      @default("active") // active | completed
  startDate   DateTime?   // 旅程出发日期
  endDate     DateTime?   // 旅程结束日期
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  places      RoutePlace[]

  @@index([userId])
  @@index([userId, type])
  @@map("routes")
}

// 路线-地点中间表（有序）
model RoutePlace {
  id        String   @id @default(cuid())
  routeId   String
  placeId   String
  sortOrder Int      @default(0) // 排序序号
  dayLabel  String?  // 旅程天标注，如 "Day 1"
  notes     String?  // 该地点在路线中的备注
  createdAt DateTime @default(now())
  route     Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([routeId, placeId])
  @@index([placeId])
  @@map("route_places")
}

// ========== 后台管理相关模型 ==========

// 素材资源 —— 主题插画、装饰图标、空状态插画等
model Asset {
  id         String   @id @default(cuid())
  category   String   // theme_illust | theme_deco | empty_state | tag_icon | logo
  key        String   // 资源标识，如 "night.illustUrl"
  name       String   // 资源名称
  url        String   // COS URL
  mimeType   String   // image/png | image/svg+xml
  fileSize   Int      // 文件大小（字节）
  status     String   @default("active") // active | inactive
  uploadedBy String   // 上传管理员 ID
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([category, status])
  @@map("assets")
}

// 主题配置版本 —— 远程下发给小程序的主题配置
model ThemeConfig {
  id        String   @id @default(cuid())
  version   String   @unique // 版本号
  config    Json     // 完整的 ThemeResource[] JSON
  isActive  Boolean  @default(false) // 当前生效版本
  updatedBy String   // 更新管理员 ID
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("theme_configs")
}

// 用户反馈 —— 小程序用户提交的反馈
model Feedback {
  id         String   @id @default(cuid())
  userId     String?  // 反馈用户 ID
  openid     String?  // 用户 openid
  type       String   // bug | suggestion | complaint | other
  content    String   // 反馈内容
  images     String[] // 截图 URL 列表
  contact    String?  // 联系方式
  appVersion String?  // 小程序版本号
  platform   String?  // 设备信息
  status     String   @default("pending") // pending | processing | resolved | closed
  reply      String?  // 管理员回复
  repliedBy  String?  // 回复管理员 ID
  repliedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status, createdAt])
  @@index([userId])
  @@map("feedbacks")
}

// 公告 —— 管理员发布给小程序用户的通知
model Announcement {
  id           String    @id @default(cuid())
  title        String    // 公告标题
  content      String    // 公告内容（支持纯文本）
  type         String    @default("popup") // popup | banner | update_tip
  isActive     Boolean   @default(false) // 是否生效
  minVersion   String?   // 最低版本要求（低于此版本不展示）
  linkUrl      String?   // 「了解更多」跳转链接
  startAt      DateTime? // 生效开始时间
  endAt        DateTime? // 生效结束时间
  publishedBy  String?   // 发布管理员 ID
  publishedAt  DateTime? // 发布时间
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([isActive, type])
  @@map("announcements")
}

// 管理员操作日志
model AdminLog {
  id        String   @id @default(cuid())
  adminId   String   // 操作管理员 ID
  action    String   // 操作类型
  target    String?  // 操作目标 ID
  detail    String?  // 操作详情（JSON 字符串）
  ip        String?  // 操作 IP
  createdAt DateTime @default(now())

  @@index([adminId, createdAt])
  @@map("admin_logs")
}
