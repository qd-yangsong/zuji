# Server
PORT=3000
NODE_ENV=development

# Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zuji?schema=public"

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT（请替换为随机字符串）
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=30d

# WeChat MiniProgram（请替换为你的 AppID 和 Secret）
WX_APPID=your-wx-appid
WX_SECRET=your-wx-secret

# Tencent COS（请替换为你的 COS 凭证）
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=your-cos-secret-key
COS_BUCKET=your-cos-bucket
COS_REGION=ap-shanghai
